@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "External Login";
}

<div class="login-box">
    <div class="card card-outline card-primary">
        <div class="card-body text-center">
            <i class="fa fa-plug fa-3x text-primary mb-3"></i>
            <p>The provider callback endpoint is registered and ready for provider-specific mapping.</p>
            <a asp-action="Login" class="btn btn-primary btn-block">Back to sign in</a>
        </div>
    </div>
</div>
