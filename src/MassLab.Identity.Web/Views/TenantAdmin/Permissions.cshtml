@model TenantPermissionsPage
@{
    ViewData["Title"] = "Permissions";
    string NextDir(string column) => Model.Sort == column && Model.Direction == "asc" ? "desc" : "asc";
}

<div class="card card-primary">
    <div class="card-header"><h3 class="card-title">Create Permission</h3></div>
    <form asp-action="CreatePermission" method="post">
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-row">
                <div class="form-group col-md-4"><label>Name</label><input name="name" class="form-control" placeholder="users.manage" /></div>
                <div class="form-group col-md-3"><label>Category <span class="text-danger">*</span></label><input name="category" class="form-control" placeholder="users" required /></div>
                <div class="form-group col-md-5"><label>Description</label><input name="description" class="form-control" placeholder="Optional" /></div>
            </div>
        </div>
        <div class="card-footer"><button class="btn btn-primary" type="submit"><i class="fa fa-plus"></i> Create permission</button></div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Permissions</h3>
        <div class="card-tools">
            <form method="get" class="input-group input-group-sm" style="width: 280px;">
                <input name="q" value="@Model.Query" class="form-control float-right" placeholder="Filter permissions" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="dir" value="@Model.Direction" />
                <div class="input-group-append"><button class="btn btn-default" type="submit"><i class="fa fa-search"></i></button></div>
            </form>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap">
            <thead>
            <tr>
                <th><a asp-action="Permissions" asp-route-q="@Model.Query" asp-route-sort="name" asp-route-dir="@NextDir("name")">Name</a></th>
                <th><a asp-action="Permissions" asp-route-q="@Model.Query" asp-route-sort="category" asp-route-dir="@NextDir("category")">Category</a></th>
                <th><a asp-action="Permissions" asp-route-q="@Model.Query" asp-route-sort="description" asp-route-dir="@NextDir("description")">Description</a></th>
                <th class="text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var permission in Model.Permissions)
            {
                <tr>
                    <td><code>@permission.Name</code></td>
                    <td>@permission.Category</td>
                    <td>@(string.IsNullOrWhiteSpace(permission.Description) ? "-" : permission.Description)</td>
                    <td class="text-right">
                        <button class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editPermission-@permission.Id"><i class="fa fa-pencil"></i> Edit</button>
                        <form asp-action="DeletePermission" asp-route-id="@permission.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this permission?');">
                            <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fa fa-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@foreach (var permission in Model.Permissions)
{
    <div class="modal fade" id="editPermission-@permission.Id" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="EditPermission" asp-route-id="@permission.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit permission</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group"><label>Name</label><input name="name" value="@permission.Name" class="form-control" /></div>
                        <div class="form-group"><label>Category <span class="text-danger">*</span></label><input name="category" value="@permission.Category" class="form-control" required /></div>
                        <div class="form-group"><label>Description</label><input name="description" value="@permission.Description" class="form-control" placeholder="Optional" /></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save permission</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
