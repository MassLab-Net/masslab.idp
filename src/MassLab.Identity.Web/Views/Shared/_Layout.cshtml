<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MassLab Identity</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fa fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Dashboard" class="nav-link">Admin</a>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-link nav-link"><i class="fa fa-sign-out"></i> Logout</button>
                    </form>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a asp-controller="Home" asp-action="Index" class="brand-link">
                <span class="brand-text font-weight-light">MassLab Identity</span>
            </a>
            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item">
                            <a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Dashboard" class="nav-link">
                                <i class="nav-icon fa fa-dashboard"></i>
                                <p>Overview</p>
                            </a>
                        </li>
                        <li class="nav-header">TENANT</li>
                        <li class="nav-item">
                            <a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Organizations" class="nav-link">
                                <i class="nav-icon fa fa-building"></i>
                                <p>Organizations</p>
                            </a>
                        </li>
                        <li class="nav-header">ACCESS CONTROL</li>
                        <li class="nav-item">
                            <a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Dashboard" class="nav-link">
                                <i class="nav-icon fa fa-line-chart"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Users" class="nav-link"><i class="nav-icon fa fa-users"></i><p>Users</p></a></li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Roles" class="nav-link"><i class="nav-icon fa fa-id-badge"></i><p>Roles</p></a></li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Permissions" class="nav-link"><i class="nav-icon fa fa-key"></i><p>Permissions</p></a></li>
                        <li class="nav-header">PLATFORM</li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Applications" class="nav-link"><i class="nav-icon fa fa-window-restore"></i><p>Applications</p></a></li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Providers" class="nav-link"><i class="nav-icon fa fa-plug"></i><p>Login Providers</p></a></li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Sessions" class="nav-link"><i class="nav-icon fa fa-clock-o"></i><p>Sessions</p></a></li>
                        <li class="nav-item"><a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Audit" class="nav-link"><i class="nav-icon fa fa-list-alt"></i><p>Audit Logs</p></a></li>
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1>@ViewData["Title"]</h1>
                        </div>
                    </div>
                </div>
            </section>
            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <footer class="main-footer">
            <strong>&copy; 2026 MassLab Identity.</strong>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
