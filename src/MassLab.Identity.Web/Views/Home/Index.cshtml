@{
    ViewData["Title"] = "Identity Dashboard";
}

<div class="row">
    <div class="col-lg-4 col-12">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>SSO</h3>
                <p>OpenID Connect and OAuth2</p>
            </div>
            <div class="icon"><i class="fa fa-sign-in"></i></div>
            <a asp-controller="Account" asp-action="Login" class="small-box-footer">Open login <i class="fa fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-4 col-12">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>Tenant</h3>
                <p>Users, roles, clients, sessions</p>
            </div>
            <div class="icon"><i class="fa fa-users"></i></div>
            <a asp-route="@MassLab.Identity.Web.Routing.AdminRouteNames.Dashboard" class="small-box-footer">Open admin <i class="fa fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg-4 col-12">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>System</h3>
                <p>Tenants and domains</p>
            </div>
            <div class="icon"><i class="fa fa-building"></i></div>
            <a asp-controller="SystemAdmin" asp-action="Index" class="small-box-footer">Manage system <i class="fa fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Identity Platform</h3>
    </div>
    <div class="card-body">
        Multi-tenant SSO, OpenID Connect, OAuth2, users, roles, permissions, providers, sessions, and audit logs.
    </div>
</div>
