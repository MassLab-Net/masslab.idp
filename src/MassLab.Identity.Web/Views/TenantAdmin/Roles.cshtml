@model MassLab.Identity.Web.Controllers.TenantRolesPage
@{
    ViewData["Title"] = "Roles";
    string NextDir(string column) => Model.Sort == column && Model.Direction == "asc" ? "desc" : "asc";
    var permissionGroups = Model.Permissions
        .GroupBy(x => string.IsNullOrWhiteSpace(x.Category) ? "Ungrouped" : x.Category)
        .OrderBy(x => x.Key)
        .ToList();
}

<div class="card card-primary">
    <div class="card-header"><h3 class="card-title">Create Role</h3></div>
    <form asp-action="CreateRole" method="post">
        <div class="card-body">
            <div class="form-row">
                <div class="form-group col-md-4"><label>Name</label><input name="name" class="form-control" /></div>
                <div class="form-group col-md-8"><label>Description</label><input name="description" class="form-control" /></div>
            </div>
        </div>
        <div class="card-footer"><button class="btn btn-primary" type="submit"><i class="fa fa-plus"></i> Create role</button></div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Roles</h3>
        <div class="card-tools">
            <form method="get" class="input-group input-group-sm" style="width: 280px;">
                <input name="q" value="@Model.Query" class="form-control float-right" placeholder="Filter roles" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="dir" value="@Model.Direction" />
                <div class="input-group-append"><button class="btn btn-default" type="submit"><i class="fa fa-search"></i></button></div>
            </form>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap">
            <thead>
            <tr>
                <th><a asp-action="Roles" asp-route-q="@Model.Query" asp-route-sort="name" asp-route-dir="@NextDir("name")">Name</a></th>
                <th><a asp-action="Roles" asp-route-q="@Model.Query" asp-route-sort="description" asp-route-dir="@NextDir("description")">Description</a></th>
                <th>Permissions</th>
                <th class="text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var role in Model.Roles)
            {
                var assigned = Model.AssignedPermissionIds.TryGetValue(role.Id, out var permissions) ? permissions : new HashSet<Guid>();
                <tr>
                    <td>@role.Name</td>
                    <td>@role.Description</td>
                    <td>@assigned.Count</td>
                    <td class="text-right">
                        <button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#assignPermissions-@role.Id"><i class="fa fa-check-square-o"></i> Permissions</button>
                        <button class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editRole-@role.Id"><i class="fa fa-pencil"></i> Edit</button>
                        <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this role?');">
                            <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fa fa-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@foreach (var role in Model.Roles)
{
    var assigned = Model.AssignedPermissionIds.TryGetValue(role.Id, out var permissions) ? permissions : new HashSet<Guid>();
    <div class="modal fade" id="assignPermissions-@role.Id" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <form asp-action="SetRolePermissions" asp-route-roleId="@role.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Assign permissions: @role.Name</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body permission-tree">
                        @foreach (var group in permissionGroups)
                        {
                            var groupId = $"permission-group-{role.Id}-{Math.Abs(group.Key.GetHashCode())}";
                            var allChecked = group.All(permission => assigned.Contains(permission.Id));
                            var anyChecked = group.Any(permission => assigned.Contains(permission.Id));
                            <div class="permission-group">
                                <div class="permission-group-title">
                                    <div class="custom-control custom-checkbox">
                                        <input class="custom-control-input permission-group-check" type="checkbox" id="@groupId" data-group="@groupId" checked="@allChecked" data-partial="@(!allChecked && anyChecked).ToString().ToLowerInvariant()" />
                                        <label class="custom-control-label" for="@groupId"><i class="fa fa-folder-open"></i> @group.Key</label>
                                    </div>
                                </div>
                                <div class="permission-children">
                                    @foreach (var permission in group)
                                    {
                                        <div class="custom-control custom-checkbox mb-1">
                                            <input class="custom-control-input permission-child-check @groupId" type="checkbox" id="permission-@role.Id-@permission.Id" name="permissionIds" value="@permission.Id" checked="@assigned.Contains(permission.Id)" data-group="@groupId" />
                                            <label class="custom-control-label" for="permission-@role.Id-@permission.Id"><code>@permission.Name</code> <span class="text-muted">@permission.Description</span></label>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save permissions</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editRole-@role.Id" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="EditRole" asp-route-id="@role.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit role</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group"><label>Name</label><input name="name" value="@role.Name" class="form-control" /></div>
                        <div class="form-group"><label>Description</label><input name="description" value="@role.Description" class="form-control" /></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save role</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        (function () {
            function syncGroup(groupId) {
                var children = document.querySelectorAll('.permission-child-check.' + CSS.escape(groupId));
                var group = document.querySelector('.permission-group-check[data-group="' + groupId + '"]');
                if (!group || children.length === 0) return;
                var checked = Array.prototype.filter.call(children, function (item) { return item.checked; }).length;
                group.checked = checked === children.length;
                group.indeterminate = checked > 0 && checked < children.length;
            }

            document.querySelectorAll('.permission-group-check').forEach(function (group) {
                if (group.dataset.partial === 'true') {
                    group.indeterminate = true;
                }
                group.addEventListener('change', function () {
                    var groupId = group.dataset.group;
                    document.querySelectorAll('.permission-child-check.' + CSS.escape(groupId)).forEach(function (child) {
                        child.checked = group.checked;
                    });
                    group.indeterminate = false;
                });
            });

            document.querySelectorAll('.permission-child-check').forEach(function (child) {
                child.addEventListener('change', function () {
                    syncGroup(child.dataset.group);
                });
            });
        })();
    </script>
}
