@model ForgotPasswordInput
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="masslab-auth-card-page">
    <div class="masslab-auth-card">
        <a asp-action="Login" class="masslab-login__brand masslab-login__brand--compact">
            <img src="~/images/masslab-logo-full.png" asp-append-version="true" alt="MassLab" class="masslab-login__brand-image masslab-login__brand-image--compact" />
        </a>
        <div class="masslab-auth-card__header">
            <h1>Forgot password</h1>
            <p>Enter your email to receive a reset link.</p>
        </div>
        <form asp-action="ForgotPassword" method="post" class="masslab-auth-card__form">
            <div asp-validation-summary="All" class="masslab-login__validation @(ViewData.ModelState.IsValid ? "validation-summary-valid" : "validation-summary-errors")"></div>
            <div class="form-group masslab-login__field">
                <label asp-for="Email">Email</label>
                <div class="masslab-login__input-wrap">
                    <span class="fa fa-envelope masslab-login__input-icon" aria-hidden="true"></span>
                    <input asp-for="Email" class="form-control masslab-login__input" placeholder="you@company.com" autocomplete="username" />
                </div>
            </div>
            <button type="submit" class="btn masslab-login__submit">Send reset link</button>
        </form>
        <div class="masslab-auth-card__footer">
            <a asp-action="Login" class="masslab-login__link">Back to sign in</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
