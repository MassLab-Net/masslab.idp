@model IReadOnlyCollection<AdminAuditLogDto>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="card">
    <div class="card-header"><h3 class="card-title">Audit Logs</h3></div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap">
            <thead><tr><th>Time</th><th>Event</th><th>Result</th><th>Actor</th><th>Target</th><th>IP</th><th>Trace</th></tr></thead>
            <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.CreatedAt</td>
                    <td><code>@log.EventType</code></td>
                    <td><span class="badge @(log.Succeeded ? "badge-success" : "badge-danger")">@log.Result</span></td>
                    <td>@log.ActorType @log.ActorUserId</td>
                    <td>@log.TargetType @log.TargetId</td>
                    <td>@log.IpAddress</td>
                    <td><code>@log.TraceId</code></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
