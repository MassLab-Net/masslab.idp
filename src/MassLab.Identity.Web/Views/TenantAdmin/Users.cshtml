@model TenantUsersPage
@{
    ViewData["Title"] = "Users";
    string NextDir(string column) => Model.Sort == column && Model.Direction == "asc" ? "desc" : "asc";
}

<div class="card card-primary">
    <div class="card-header"><h3 class="card-title">Create User</h3></div>
    <form asp-action="CreateUser" method="post">
        <div class="card-body">
            <div class="form-row">
                <div class="form-group col-md-3"><label>Email</label><input name="email" class="form-control" /></div>
                <div class="form-group col-md-3"><label>Display name</label><input name="displayName" class="form-control" /></div>
                <div class="form-group col-md-3"><label>Password</label><input name="password" type="password" class="form-control" /></div>
                <div class="form-group col-md-3">
                    <label>Tenant admin</label>
                    <select name="isTenantAdmin" class="form-control"><option value="false">No</option><option value="true">Yes</option></select>
                </div>
            </div>
        </div>
        <div class="card-footer"><button class="btn btn-primary" type="submit"><i class="fa fa-plus"></i> Create user</button></div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Users</h3>
        <div class="card-tools">
            <form method="get" class="input-group input-group-sm" style="width: 280px;">
                <input name="q" value="@Model.Query" class="form-control float-right" placeholder="Filter users" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="dir" value="@Model.Direction" />
                <div class="input-group-append"><button class="btn btn-default" type="submit"><i class="fa fa-search"></i></button></div>
            </form>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        <table class="table table-hover text-nowrap">
            <thead>
            <tr>
                <th><a asp-action="Users" asp-route-q="@Model.Query" asp-route-sort="email" asp-route-dir="@NextDir("email")">Email</a></th>
                <th><a asp-action="Users" asp-route-q="@Model.Query" asp-route-sort="name" asp-route-dir="@NextDir("name")">Name</a></th>
                <th><a asp-action="Users" asp-route-q="@Model.Query" asp-route-sort="status" asp-route-dir="@NextDir("status")">Status</a></th>
                <th>Admin</th>
                <th>Roles</th>
                <th class="text-right">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                var assigned = Model.AssignedRoleIds.TryGetValue(user.Id, out var roles) ? roles : new HashSet<Guid>();
                <tr>
                    <td>@user.Email</td>
                    <td>@user.DisplayName</td>
                    <td><span class="badge @(user.IsEnabled ? "badge-success" : "badge-secondary")">@(user.IsEnabled ? "Enabled" : "Disabled")</span></td>
                    <td>@(user.IsTenantAdmin ? "Tenant" : user.IsSystemAdmin ? "System" : "-")</td>
                    <td>@assigned.Count</td>
                    <td class="text-right">
                        <button class="btn btn-sm btn-outline-primary" data-toggle="modal" data-target="#assignRoles-@user.Id"><i class="fa fa-check-square-o"></i> Roles</button>
                        <button class="btn btn-sm btn-outline-secondary" data-toggle="modal" data-target="#editUser-@user.Id"><i class="fa fa-pencil"></i> Edit</button>
                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this user?');">
                            <button class="btn btn-sm btn-outline-danger" type="submit"><i class="fa fa-trash"></i> Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@foreach (var user in Model.Users)
{
    var assigned = Model.AssignedRoleIds.TryGetValue(user.Id, out var roles) ? roles : new HashSet<Guid>();
    <div class="modal fade" id="assignRoles-@user.Id" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="SetUserRoles" asp-route-userId="@user.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Assign roles: @user.Email</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        @foreach (var role in Model.Roles)
                        {
                            <div class="custom-control custom-checkbox mb-2">
                                <input class="custom-control-input" type="checkbox" id="role-@user.Id-@role.Id" name="roleIds" value="@role.Id" checked="@assigned.Contains(role.Id)" />
                                <label class="custom-control-label" for="role-@user.Id-@role.Id">@role.Name</label>
                            </div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save roles</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editUser-@user.Id" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="EditUser" asp-route-id="@user.Id" method="post">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit user</h5>
                        <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group"><label>Email</label><input name="email" value="@user.Email" class="form-control" /></div>
                        <div class="form-group"><label>Display name</label><input name="displayName" value="@user.DisplayName" class="form-control" /></div>
                        <div class="custom-control custom-checkbox mb-2">
                            <input class="custom-control-input" id="enabled-@user.Id" type="checkbox" name="isEnabled" value="true" checked="@user.IsEnabled" />
                            <input type="hidden" name="isEnabled" value="false" />
                            <label class="custom-control-label" for="enabled-@user.Id">Enabled</label>
                        </div>
                        <div class="custom-control custom-checkbox">
                            <input class="custom-control-input" id="tenant-admin-@user.Id" type="checkbox" name="isTenantAdmin" value="true" checked="@user.IsTenantAdmin" />
                            <input type="hidden" name="isTenantAdmin" value="false" />
                            <label class="custom-control-label" for="tenant-admin-@user.Id">Tenant admin</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save user</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
