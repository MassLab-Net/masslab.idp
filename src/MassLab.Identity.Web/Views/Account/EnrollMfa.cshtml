@model MfaEnrollViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Enroll MFA";
}

<div class="login-box">
    <div class="card">
        <div class="card-header"><h3 class="card-title">Enroll MFA</h3></div>
        <div class="card-body">
            <p>Secret: <code>@Model.Secret</code></p>
            <p class="small text-muted">Authenticator URI: <code>@Model.AuthenticatorUri</code></p>
            <form asp-action="MfaChallenge" method="post">
                <div class="input-group mb-3">
                    <input name="code" class="form-control" placeholder="6-digit code" />
                    <div class="input-group-append"><div class="input-group-text"><span class="fa fa-shield"></span></div></div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Verify</button>
            </form>
        </div>
    </div>
</div>
