@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Email Sent";
}

<div class="login-box">
    <div class="card card-outline card-primary">
        <div class="card-body text-center">
            <i class="fa fa-envelope-o fa-3x text-primary mb-3"></i>
            <p>If the account exists, an email has been queued.</p>
            <a asp-action="Login" class="btn btn-primary btn-block">Back to sign in</a>
        </div>
    </div>
</div>
