@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Email Verified";
}

<div class="masslab-auth-card-page">
    <div class="masslab-auth-card masslab-auth-card--center">
        <div class="masslab-auth-card__icon masslab-auth-card__icon--success">
            <i class="fa fa-check-circle"></i>
        </div>
        <div class="masslab-auth-card__header">
            <h1>Email verified</h1>
            <p>Your email address has been confirmed successfully.</p>
        </div>
        <a asp-action="Login" class="btn masslab-login__submit">Sign in</a>
    </div>
</div>
