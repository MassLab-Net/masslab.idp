@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Access Denied";
}

<div class="masslab-auth-card-page">
    <div class="masslab-auth-card masslab-auth-card--center">
        <div class="masslab-auth-card__icon masslab-auth-card__icon--danger">
            <i class="fa fa-ban"></i>
        </div>
        <div class="masslab-auth-card__header">
            <h1>Access denied</h1>
            <p>You do not have permission to access this page with the current account.</p>
        </div>
        <a asp-action="Login" class="btn masslab-login__submit">Back to sign in</a>
    </div>
</div>
